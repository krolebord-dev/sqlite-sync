{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sqlite-sync-server",
  "main": "src/server/event-log-server.ts",
  "compatibility_date": "2025-12-02",
  "migrations": [
    {
      "new_sqlite_classes": ["EventLogServer"],
      "tag": "v1"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "EventLogServer",
        "name": "EventLogServer"
      }
    ]
  },
  "observability": {
    "enabled": true
  }
}
