{
  "name": "productivity",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3001",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "VITE_APP_URL=https://productivity.krolebord.com npm run build && wrangler deploy",
    "db:local:init": "wrangler d1 execute productivity-db --local --command \"SELECT 1;\"",
    "db:local:migrate": "wrangler d1 migrations apply productivity-db --local",
    "db:new-migration": "echo 'Enter migration name: ' && read MIGRATION_NAME && wrangler d1 migrations create productivity-db $MIGRATION_NAME",
    "generate:types:db": "DB_PATH=$(find ./.wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name \"*.sqlite\" -print -quit) && kysely-codegen --dialect=sqlite --url=$DB_PATH --out-file=src/lib/db-types.ts --exclude-pattern=\"_cf_METADATA\"",
    "generate:types:env": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.21.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@orpc/client": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/tanstack-query": "^1.13.4",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.6",
    "@sqlite-sync/cloudflare": "workspace:*",
    "@sqlite-sync/core": "workspace:*",
    "@sqlite-sync/react": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.156.0",
    "@tanstack/router-plugin": "^1.156.0",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "kysely": "^0.28.10",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.563.0",
    "partyserver": "^0.1.0",
    "partysocket": "^1.1.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.1",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "^0.4.1",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "kysely-codegen": "^0.19.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "wrangler": "^4.60.0"
  }
}
