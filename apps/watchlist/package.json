{
  "name": "watchlist",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "deploy": "VITE_APP_URL=https://watchlist.krolebord.com npm run build && wrangler deploy",
    "db:local:init": "wrangler d1 execute watchlist-admin --local --command \"SELECT 1;\"",
    "db:local:migrate": "wrangler d1 migrations apply watchlist-admin --local",
    "db:new-migration": "echo 'Enter migration name: ' && read MIGRATION_NAME && wrangler d1 migrations create watchlist-admin $MIGRATION_NAME",
    "generate:types:db": "DB_PATH=$(find ./.wrangler/state/v3/d1/miniflare-D1DatabaseObject -type f -name \"*.sqlite\" -print -quit) && kysely-codegen --dialect=sqlite --url=$DB_PATH --out-file=src/lib/db-types.ts --exclude-pattern=\"_cf_METADATA\"",
    "generate:types:env": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.21.2",
    "@hookform/resolvers": "^5.2.2",
    "@openrouter/ai-sdk-provider": "^2.0.1",
    "@orpc/client": "^1.13.4",
    "@orpc/server": "^1.13.4",
    "@orpc/tanstack-query": "^1.13.4",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^1.0.6",
    "@sqlite-sync/cloudflare": "workspace:*",
    "@sqlite-sync/core": "workspace:*",
    "@sqlite-sync/react": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "^0.9.2",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.156.0",
    "@tanstack/react-router-devtools": "^1.156.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@tanstack/router-plugin": "^1.156.0",
    "ai": "^6.0.49",
    "arctic": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jotai": "^2.16.2",
    "jotai-family": "^1.0.1",
    "kysely": "^0.28.10",
    "kysely-d1": "^0.4.0",
    "lucide-react": "^0.563.0",
    "next-themes": "^0.4.6",
    "partyserver": "^0.1.0",
    "partysocket": "^1.1.10",
    "pupa": "^3.3.0",
    "react": "^19.2.3",
    "react-day-picker": "^9.13.0",
    "react-dom": "^19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "2.15.4",
    "resend": "^6.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tmdb-ts": "^2.2.0",
    "tw-animate-css": "^1.3.6",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.5",
    "workers-ai-provider": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.17",
    "@tanstack/devtools-vite": "^0.4.1",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "kysely-codegen": "^0.19.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "web-vitals": "^5.1.0",
    "wrangler": "^4.60.0"
  }
}
