{
  "name": "watchlist",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:app": "vite",
    "cf-typegen": "wrangler types",
    "format": "biome check --write",
    "build": "tsc -b && vite build",
    "deploy": "pnpm run build && wrangler deploy",
    "db:generate": "drizzle-kit generate --config=\"worker/main/db/drizzle.config.ts\"",
    "db:migrate:prod": "wrangler d1 migrations apply watchlist-main --remote",
    "db:migrate:local": "wrangler d1 migrations apply watchlist-main --local",
    "db:studio:prod": "drizzle-kit studio --config=\"worker/main/db/drizzle.config.ts\"",
    "db:studio:local": "cross-env LOCAL=true drizzle-kit studio --config=\"worker/main/db/drizzle.config.ts\"",
    "db:push:local": "cross-env LOCAL=true drizzle-kit push --config=\"worker/main/db/drizzle.config.ts\"",
    "email:preview": "email dev --dir worker/emails"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@cloudflare/workers-types": "^4.20251004.0",
    "@tailwindcss/postcss": "^4.1.14",
    "@tanstack/router-devtools": "^1.132.41",
    "@tanstack/router-plugin": "^1.132.41",
    "@types/node": "^22.15.17",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.5",
    "postcss": "^8.5.6",
    "react-email": "^4.2.12",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.3",
    "vite": "^7.1.9",
    "vite-plugin-pwa": "^1.0.3",
    "wrangler": "^4.42.0"
  },
  "dependencies": {
    "@sqlite-sync/core": "workspace:*",
    "@sqlite-sync/react": "workspace:*",
    "@formkit/auto-animate": "^0.9.0",
    "@hookform/resolvers": "^3.10.0",
    "@oslojs/otp": "^1.1.0",
    "@paralleldrive/cuid2": "^2.2.2",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-email/components": "^0.5.5",
    "@react-email/render": "^1.3.1",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-router": "^1.132.41",
    "@tanstack/zod-adapter": "^1.132.41",
    "@trpc/client": "11.6.0",
    "@trpc/react-query": "11.6.0",
    "@trpc/server": "11.6.0",
    "ai": "^5.0.60",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.0.2",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.6",
    "lucide-react": "^0.544.0",
    "motion": "^12.23.22",
    "partyserver": "^0.0.75",
    "partysocket": "^1.1.6",
    "react": "^19.2.0",
    "react-day-picker": "8.10.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.56.3",
    "remeda": "^2.32.0",
    "resend": "^6.1.2",
    "spin-delay": "^2.0.1",
    "superjson": "^2.2.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tmdb-ts": "^2.0.2",
    "vaul": "^1.1.2",
    "workers-ai-provider": "^2.0.0",
    "zod": "^4.1.11",
    "zustand": "^5.0.8"
  }
}
