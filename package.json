{
  "name": "sqlite-sync-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @sqlite-sync/example dev",
    "dev:server": "pnpm --filter @sqlite-sync/example dev:server",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "publish:packages": "pnpm -r publish --access public",
    "publish:dry": "pnpm -r publish --access public --dry-run",
    "version:patch": "pnpm -r exec npm version patch",
    "version:minor": "pnpm -r exec npm version minor",
    "version:major": "pnpm -r exec npm version major",
    "format": "biome check --write"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.12",
    "@types/node": "^22.19.7",
    "globals": "^16.5.0",
    "tsup": "^8.5.1",
    "typescript": "~5.9.3"
  }
}
