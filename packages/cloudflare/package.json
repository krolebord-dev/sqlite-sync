{
  "name": "@sqlite-sync/cloudflare",
  "version": "0.0.2",
  "description": "Cloudflare utilities for @sqlite-sync/core",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krolebord/sqlite-sync.git",
    "directory": "packages/cloudflare"
  },
  "keywords": [
    "sqlite",
    "sync",
    "cloudflare",
    "workers",
    "durable-objects",
    "kysely"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@sqlite-sync/source": "./src/index.ts",
      "workerd": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./jobs": {
      "@sqlite-sync/source": "./src/jobs/index.ts",
      "workerd": "./src/jobs/index.ts",
      "types": "./dist/jobs.d.ts",
      "import": "./dist/jobs.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./jobs": {
        "types": "./dist/jobs.d.ts",
        "import": "./dist/jobs.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@sqlite-sync/core": "workspace:*",
    "@standard-schema/spec": "^1.1.0"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "^4.0.0",
    "kysely": "^0.28.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260124.0",
    "kysely": "^0.28.10",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3"
  }
}
