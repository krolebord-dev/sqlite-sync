{
  "name": "@sqlite-sync/core",
  "version": "0.0.2",
  "description": "SQLite synchronization library with CRDT support",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krolebord/sqlite-sync.git",
    "directory": "packages/core"
  },
  "keywords": [
    "sqlite",
    "sync",
    "crdt",
    "offline-first",
    "local-first"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@sqlite-sync/source": "./src/index.ts",
      "workerd": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./worker": {
      "@sqlite-sync/source": "./src/worker.ts",
      "workerd": "./src/worker.ts",
      "types": "./dist/worker.d.ts",
      "import": "./dist/worker.js"
    },
    "./server": {
      "@sqlite-sync/source": "./src/server/index.ts",
      "workerd": "./src/server/index.ts",
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./worker": {
        "types": "./dist/worker.d.ts",
        "import": "./dist/worker.js"
      },
      "./server": {
        "types": "./dist/server.d.ts",
        "import": "./dist/server.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@sqlite.org/sqlite-wasm": "catalog:",
    "kysely": "^0.28.10",
    "retry-as-promised": "^7.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3"
  }
}
