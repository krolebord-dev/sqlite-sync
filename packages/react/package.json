{
  "name": "@sqlite-sync/react",
  "version": "0.0.1",
  "description": "React bindings for @sqlite-sync/core",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krolebord/sqlite-sync.git",
    "directory": "packages/react"
  },
  "keywords": [
    "sqlite",
    "sync",
    "react",
    "hooks",
    "offline-first",
    "local-first"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "@sqlite-sync/source": "./src/index.ts",
      "workerd": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@sqlite-sync/core": "workspace:*"
  },
  "peerDependencies": {
    "kysely": "^0.28.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.9",
    "kysely": "^0.28.10",
    "react": "^19.2.3",
    "tsup": "^8.3.5",
    "typescript": "~5.9.3"
  }
}
